# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.

# ──────────────────────────────────────────────────────────────
# Supabase (https://app.supabase.com → Project → Settings → API)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Server-only. Never expose to the client.

# ──────────────────────────────────────────────────────────────
# Fireworks AI (https://fireworks.ai → API Keys)
# Default: Qwen3.6 Plus (Alibaba flagship; best Russian quality).
#   $0.50/M uncached input · $0.10/M cached input · $3.00/M output
# Fallback: Llama 3.3 70B if Qwen Russian outputs disappoint in W2 A/B.
#   $0.90/M input + $0.90/M output. Use:
#     COACH_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
# Keep the system prompt byte-stable so prompt caching kicks in.
# ──────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=fw-...
COACH_MODEL=accounts/fireworks/models/qwen3p6-plus

# ──────────────────────────────────────────────────────────────
# Stripe (https://dashboard.stripe.com → Developers → API keys)
# Start in test mode; switch to live before launch.
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_FAMILY_MONTHLY=price_...
STRIPE_PRICE_FAMILY_YEARLY=price_...

# ──────────────────────────────────────────────────────────────
# PostHog (https://app.posthog.com → Project Settings)
# EU cloud recommended for CIS users.
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ──────────────────────────────────────────────────────────────
# Resend (https://resend.com) — for transactional emails (D1/D3/D7 nudges,
# first-analysis email). Free tier: 100 emails/day.
# Optional for MVP day-1; needed by day 4.
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@sharpki.app

# ──────────────────────────────────────────────────────────────
# Next.js
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # production: https://sharpki.app
NODE_ENV=development
